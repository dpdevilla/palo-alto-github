
<div class="footer-cor-seal" style="text-align:center; margin: 10px 0;">
  <a href="https://piliani.com.ph/pages/registration-certificate" target="_blank" rel="noopener noreferrer">
    <img 
src="https://cdn.shopify.com/s/files/1/0633/7786/6990/files/NPC.png?v=1754546196&width=120"
alt="National Privacy Commission Certificate of Registration seal"
width="120"
height="80"
loading="lazy"
decoding="async">
  </a>
</div>
<div class="social-sharing-wrapper">
  {%- if show_social_links -%}
    {%- if settings.social_instagram_link != blank -%}
      <a
        class="social-sharing-icon instagram"
        rel="noopener"
        href="{{ settings.social_instagram_link }}"
        title="{{ 'footer.socials.title' | t: social: 'Instagram', shop_name: shop.name }}"
      >
        {%- render 'icon-instagram' -%}
      </a>
    {%- endif -%}

    {%- if settings.social_tiktok_link != blank -%}
      <a
        class="social-sharing-icon tiktok"
        rel="noopener"
        href="{{ settings.social_tiktok_link }}"
        title="{{ 'footer.socials.title' | t: social: 'Tiktok', shop_name: shop.name }}"
      >
        {%- render 'icon-tiktok' -%}
      </a>
    {%- endif -%}

    {%- if settings.social_facebook_link != blank -%}
      <a
        class="social-sharing-icon facebook"
        rel="noopener"
        href="{{ settings.social_facebook_link }}"
        title="{{ 'footer.socials.title' | t: social: 'Facebook', shop_name: shop.name }}"
      >
        {%- render 'icon-facebook' -%}
      </a>
    {%- endif -%}

    {%- if settings.social_twitter_link != blank -%}
      <a
        class="social-sharing-icon twitter"
        rel="noopener"
        href="{{ settings.social_twitter_link }}"
        title="{{ 'footer.socials.title' | t: social: 'Twitter', shop_name: shop.name }}"
      >
        {%- render 'icon-twitter' -%}
      </a>
    {%- endif -%}

    {%- if settings.social_snapchat_link != blank -%}
      <a
        class="social-sharing-icon snapchat"
        rel="noopener"
        href="{{ settings.social_snapchat_link }}"
        title="{{ 'footer.socials.title' | t: social: 'Snapchat', shop_name: shop.name }}"
      >
        {%- render 'icon-snapchat' -%}
      </a>
    {%- endif -%}

    {%- if settings.social_pinterest_link != blank -%}
      <a
        class="social-sharing-icon pinterest"
        rel="noopener"
        href="{{ settings.social_pinterest_link }}"
        title="{{ 'footer.socials.title' | t: social: 'Pinterest', shop_name: shop.name }}"
      >
        {%- render 'icon-pinterest' -%}
      </a>
    {%- endif -%}

    {%- if settings.social_tumblr_link != blank -%}
      <a
        class="social-sharing-icon tumblr"
        rel="noopener"
        href="{{ settings.social_tumblr_link }}"
        title="{{ 'footer.socials.title' | t: social: 'Tumblr', shop_name: shop.name }}"
      >
        {%- render 'icon-tumblr' -%}
      </a>
    {%- endif -%}

    {%- if settings.social_youtube_link != blank -%}
      <a
        class="social-sharing-icon youtube"
        rel="noopener"
        href="{{ settings.social_youtube_link }}"
        title="{{ 'footer.socials.title' | t: social: 'Youtube', shop_name: shop.name }}"
      >
        {%- render 'icon-youtube' -%}
      </a>
    {%- endif -%}

    {%- if settings.social_rss_link != blank -%}
      <a
        class="social-sharing-icon rss"
        rel="noopener"
        href="{{ settings.social_rss_link }}"
        title="{{ 'footer.socials.rss' | t }}"
      >
        {%- render 'icon-rss-feed' -%}
      </a>
    {%- endif -%}
  {%- endif -%}

  {%- if show_follow_on_shop -%}
    <script src="{{ 'shop-pay-link.js' | asset_url }}" defer></script>
    <shop-pay-wrapper
      class="social-sharing-icon follow-on-shop"
      data-bg="{{ color_bg }}"
      data-text="{{ color_text }}"
      data-hover="{{ color_text | color_modify: 'alpha', 0.50 }}"
    >
      {{ shop | login_button: action: 'follow' }}
    </shop-pay-wrapper>
  {%- endif -%}
</div>
